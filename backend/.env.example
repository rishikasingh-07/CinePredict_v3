# Copy this to .env and fill in your values

# Gemini API Key (optional — app works without it using mock suggestions)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# CORS — set to your frontend URL in production, e.g. https://your-frontend.onrender.com
ALLOWED_ORIGINS=*

# Flask debug mode (set to false in production)
FLASK_DEBUG=false

# Port (Render sets this automatically)
PORT=5000
